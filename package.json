{
  "name": "jamie-harness",
  "version": "0.1.0",
  "description": "Minimal harness SDK for durable code-mode execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "example:manual": "bun run examples/manual.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "sdk",
    "llm",
    "harness",
    "typescript"
  ],
  "license": "MIT",
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "openai": "^6.34.0",
    "typescript": "^6.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "bun-types": "^1.3.13"
  }
}
